{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "test": "bun test src/__tests__"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@test-evals/db": "workspace:*",
    "@test-evals/env": "workspace:*",
    "@test-evals/llm": "workspace:*",
    "@test-evals/shared": "workspace:*",
    "ajv": "^8.17.1",
    "drizzle-orm": "^0.45.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "nanoid": "^5.1.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@test-evals/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
